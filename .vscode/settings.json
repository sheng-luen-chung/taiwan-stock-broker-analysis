{
  // 釘死 VS Code 用的解譯器
  // "python.defaultInterpreterPath": ".venv\\Scripts\\python.exe", // 建議註解掉，讓 VS Code 自動偵測
  // "python.venvPath": "H:/venvs", // 建議註解掉，讓 VS Code 自動偵測
  "python.terminal.activateEnvironment": true,

  // 確保 Jupyter 也用 venv（避免跑到全域 Python）
  "jupyter.askForKernelRestart": false,
  "jupyter.kernelPicker.type": "onlySuggested", 
  "jupyter.kernels.exclude": [ "Python 3" ],

  // 格式與檔案習慣（可選）
  "files.eol": "\n",
  "files.encoding": "utf8",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,

  // 建議不要手動設 PATH，讓 VS Code 自動偵測 .venv
}
